# Copy to `.env` in this folder (never commit real tokens).
# https://huggingface.co/settings/tokens

# Higher rate limits + faster downloads from the Hugging Face Hub (CLIP weights, datasets, etc.)
HF_TOKEN=hf_your_token_here

# Default index: stream huggan/wikiart, cache JPEGs under data/corpus_jpg/
# Use SEARCH_CORPUS=local to index only web/public/inspiration (12 files).
# SEARCH_CORPUS=wikiart
# HF_WIKIART_MAX=1500
# Base URL the browser will use to load GET /corpus/file/{id} (must match where uvicorn is reachable)
# SEARCH_PUBLIC_BASE=http://127.0.0.1:8000

# WikiArt + embeddings live in a DB (default: SQLite at data/corpus.db). For Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# pip install psycopg2-binary

# Optional: protect the API
# CLASSIC_SEARCH_API_KEY=
